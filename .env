# ── API ─────────────────────────────────────────────────────────────────────
# Vite proxies /api to :5000, so relative URL works for both :5173 and :5174
VITE_API_URL=/api
VITE_SOCKET_URL=http://localhost:5000

# ── Razorpay (paste your test Key ID here) ──────────────────────────────────
VITE_RAZORPAY_KEY_ID=

# ── Google Maps (optional) ──────────────────────────────────────────────────
VITE_GOOGLE_MAPS_API_KEY=

# ── App identity ─────────────────────────────────────────────────────────────
VITE_APP_NAME=ZINGER Grocery
